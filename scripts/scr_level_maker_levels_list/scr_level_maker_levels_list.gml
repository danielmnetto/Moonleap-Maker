function MakerLevel(
  _filename,
  _name,
  _author,
  _player_score,
  _perfect_score,
  _level_style,
  _record_time = -1
) constructor {
  filename = _filename;
  name = _name;
  author = _author;
  player_score = _player_score;
  perfect_score = _perfect_score;
  style = _level_style;
  record_time = _record_time;
}
